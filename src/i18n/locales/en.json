  "faq": {
    "title": "Frequently Asked Questions",
    "questions": [
      {
        "question": "When are the payouts?",
        "answer": "We make payouts once a week (we plan daily payouts in the future)."
      },
      {
        "question": "Are there any hidden fees?",
        "answer": "No. You have transparent pricing and zero hidden costs."
      },
      {
        "question": "Do I need a business?",
        "answer": "No. You drive through Get RIDO — we settle you as a partner."
      },
      {
        "question": "Can I switch from another partner?",
        "answer": "Yes. We'll help you transfer settlements and activation within 24h."
      },
      {
        "question": "What documents are required?",
        "answer": "Driver's license (min. 1 year), clean record (≤30 days), medical and psychotechnical tests, photo. Car with TAXI inspection (if required)."
      },
      {
        "question": "Can I change the settlement model?",
        "answer": "Yes — once a month."
      },
      {
        "question": "What is the Get RIDO fuel card?",
        "answer": "It's a card with fuel discount at partner stations. It's required to use the 159 PLN + 0% tax model."
      },
      {
        "question": "Does Get RIDO help with formalities?",
        "answer": "Yes — we'll guide you through the entire process, step by step."
      }
    ]
  },
